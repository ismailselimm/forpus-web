# Web3Forms erişim anahtarı (GİZLİ DEĞİL — istemci tarafında açık olması normaldir,
# e-posta adresinin takma adı gibi çalışır). İletişim formundan gelen mesajlar bu
# anahtara bağlı e-posta kutusuna (forpusyazilim@gmail.com) düşer.
#
# Almak için: https://web3forms.com → forpusyazilim@gmail.com gir → e-postana gelen
# Access Key'i buraya yapıştır. Vercel'de de "Settings → Environment Variables"
# altına aynı isimle ekle (NEXT_PUBLIC_WEB3FORMS_KEY) ve yeniden deploy et.
NEXT_PUBLIC_WEB3FORMS_KEY=
